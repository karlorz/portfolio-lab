# Portfolio-Lab Environment Configuration
# Copy to .env and adjust:  cp .env.example .env

# ── ML Features ──────────────────────────────────────────────────────
# Disabled by default — torch (63MB) + xgboost (78MB) cause OOM in full
# test suite. Set to 1 to enable MARL agents, stacking ensemble, etc.
PORTFOLIO_LAB_ENABLE_ML=0

# ── Python (uv) ──────────────────────────────────────────────────────
# uv manages the virtual env automatically. No config needed.
#   uv sync              → install core deps (fast, no ML)
#   uv sync --group ml   → install core + ML deps
#   uv run python script.py
#   uv run pytest tests/

# ── Test Modes ───────────────────────────────────────────────────────
# Smoke test (fast, ~130 tests, ~4s):
#   uv run pytest tests/test_behavioral_sentiment.py tests/test_combined_orchestrator.py tests/test_dual_momentum.py tests/test_evaluator.py
#
# Full suite (slow, ~2850 tests, several minutes):
#   uv run pytest tests/
#
# ML tests (requires PORTFOLIO_LAB_ENABLE_ML=1):
#   PORTFOLIO_LAB_ENABLE_ML=1 uv run pytest tests/ -m heavy
